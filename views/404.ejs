<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% const safeAppName = typeof appName !== "undefined" && appName ? appName : "EmbedCDN"; %>
  <% const safeStatus = typeof errorStatus !== "undefined" && errorStatus ? errorStatus : 404; %>
  <% const safeEyebrow = typeof errorEyebrow !== "undefined" && errorEyebrow ? errorEyebrow : "404 Error"; %>
  <% const safeTitle = typeof errorTitle !== "undefined" && errorTitle ? errorTitle : "That link is off the map."; %>
  <% const safeMessage = typeof errorMessage !== "undefined" && errorMessage ? errorMessage : "The file, route, or short link could not be found."; %>
  <title><%= safeStatus %> | <%= safeAppName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link href="/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="/assets/css/style.css" rel="stylesheet">
</head>

<body class="product-shell error-page" data-page="error">
  <div class="texture-layer" aria-hidden="true"></div>

  <main class="center-stage">
    <section class="container error-shell">
      <article class="error-card reveal">
        <span class="eyebrow"><%= safeEyebrow %></span>
        <div class="error-code"><%= safeStatus %></div>
        <h1><%= safeTitle %></h1>
        <p><%= safeMessage %></p>

        <div class="result-actions">
          <a href="/" class="button button-primary">
            <i class="bi bi-house-door" aria-hidden="true"></i>
            <span>Go home</span>
          </a>
          <a href="/#upload" class="button button-secondary">
            <i class="bi bi-cloud-arrow-up" aria-hidden="true"></i>
            <span>Upload file</span>
          </a>
        </div>
      </article>
    </section>
  </main>

  <script src="/assets/js/main.js"></script>
</body>

</html>
